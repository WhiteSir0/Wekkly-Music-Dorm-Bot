FROM node:22-bookworm-slim
WORKDIR /app
RUN apt-get update \
  && apt-get install -y --no-install-recommends fonts-noto-cjk \
  && rm -rf /var/lib/apt/lists/*
COPY package*.json ./
RUN npm ci --omit=dev --include=optional
COPY src ./src
COPY assets ./assets
RUN mkdir -p /app/data
CMD ["node", "src/bot/index.js"]
